"""
函数:就是一段可重复使用，用于执行特定任务的代码块
优势:
1，代码复用，可以减少重复的代码
2，结构清晰，方便维护
3，把程序分成多个模块，便于团队合作

函数的分类
1,内置函数:无需任何操作，可以直接使用
2，模块提供的函数,需要导入指定的模块才可以使用
3，自定义函数，开发者自己定义的函数（先定义再使用）

def 函数名():
    函数体
函数名()
函数需要先定义，再使用
形参：形式参数，用于接受参数,形参只能在函数体里使用
实参：实际参数，调用函数传递的值接受实参
"""
位置参数
在使用位置参数的时候，实参和形参的顺序，数量要保持一致
def order(stu,num):
    print(f'{stu}班点了{num}份午餐')
order(2603,20)

#关键字参数
#关键字参数可以和位置参数混用，但是位置参数必须在关键字参数之前
#限制传参方式
#/：前面只能使用位置参数，*后面只能使用关键字参数
#/必须在*前面
def stu(name,/,height,*,age,gender):
    print(f'我的名字{name},我今年{age},我的身高是{height},性别为{gender}')
stu('数据',180,age = 18,gender='男')

#参数默认值
#如果调用函数传递参数，那么就是使用传入的值
#如果调用函数没有传递参数，那么就使用默认值
#注意如果某个形参设置了默认值，那么该形参后的所有参数，都需要设置默认参数
def stu2(name,height,age,gender,msg = '减肥'):
    print(f'我的名字{name},我今年{age},我的身高是{height},性别为{gender},我想说{msg}')
stu2('数据',180,18,'男',1)

#可变参数
形参属于元组
def test1(*args)
    函数体
test1('鹏翔',22,'175')

#可变关键字参数
#1:传递的实参是关键字实参，形参属于字典类型的数据
def test2(**kwargs)
    函数体
test2(name='小姐',age=18,height=175)

#可变位置参数和可变关键字参数可以同时使用，但是必须先写可变位置参数
def test3(a,b,*args,c='心思',**kwargs):
    函数体
test3('阿龙','男','抽烟','喝酒',height=175,age=18)

